# ============================================================
# HAYESH — Environment Variables Template
# Copy this file to .env.local and fill in your real values
# NEVER commit .env.local to Git
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# ── STRIPE (International Payments) ──────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# For testing use sk_test_ and pk_test_ keys first
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── SIMPAISA (Pakistan Payments) ─────────────────────────────
SIMPAISA_API_KEY=your_simpaisa_api_key
SIMPAISA_WEBHOOK_SECRET=your_simpaisa_webhook_secret
NEXT_PUBLIC_SIMPAISA_MERCHANT_ID=your_merchant_id

# ── AI ROUTING ───────────────────────────────────────────────
# Dev:  OmniRoute (localhost:20128) — auto-routes through free tiers
# Prod: OpenRouter (simple/medium) + Anthropic (complex/agentic)
#
# Start OmniRoute: npm install -g omniroute && omniroute
# Dashboard: http://localhost:20128/dashboard

# OmniRoute (dev only — auto-detected, no key needed locally)
# Set this only if you expose OmniRoute on a custom port/host
# OMNIROUTE_BASE_URL=http://localhost:20128/v1

# OpenRouter (production JARVIS — free Llama 4 Maverick tier)
OPENROUTER_API_KEY=sk-or-...

# Anthropic (production AI services — Claude Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# ── VOICE TRANSLATION ────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ── LIVEKIT (Video Sessions) ─────────────────────────────────
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-server.livekit.cloud

# ── APP CONFIG ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Hayesh

# Platform commission rates (admin can override in DB)
NEXT_PUBLIC_TEACHER_COMMISSION=15
NEXT_PUBLIC_SELLER_COMMISSION=18

# ── OPTIONAL: ANALYTICS ──────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
